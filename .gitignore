# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# project docs (personal notes, not code)
# Ignore ALL markdown files except core essential ones
*.md
!CLAUDE.md
!.claude/*.md
!README.md

# local settings
.claude/settings.local.json
src/app/.claude/settings.local.json
supabase/.connection.json
.roo/
UI/

# typescript
*.tsbuildinfo
next-env.d.ts
